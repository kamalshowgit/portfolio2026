# Core
DEBUG=false
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Edit login (admin-only)
PERSONAL_EDIT_USERNAME=admin
PERSONAL_EDIT_PASSWORD=replace-with-strong-password

# Database (optional; if empty uses sqlite)
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# Security (recommended true in production)
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true

# Email delivery
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=no-reply@yourdomain.com
CONTACT_RECEIVER_EMAIL=you@example.com
